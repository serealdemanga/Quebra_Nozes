# Base URL da API.
# Deixe vazio quando o frontend e a API forem servidos na mesma origem
# (ex.: single Worker no Cloudflare servindo SPA + /v1/*).
# Preencha apenas quando a API estiver em outra origem.
VITE_API_BASE_URL=

# Ambiente do app
VITE_APP_ENV=local

# Fonte de dados do frontend
# - auto (default): local/hml -> mock, prd -> http
# - mock_local, mock_hml, http
VITE_DATA_SOURCE_MODE=auto
