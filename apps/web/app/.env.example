# Base URL da API (Cloudflare Worker). Ex: https://api.seudominio.com
VITE_API_BASE_URL=

# Ambiente do app (resolve comportamento default da factory)
VITE_APP_ENV=local

# Fonte de dados do frontend
# - auto (default): local/hml -> mock, prd -> http
# - mock_local, mock_hml, http
VITE_DATA_SOURCE_MODE=auto
